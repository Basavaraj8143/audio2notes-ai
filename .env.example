# Mistral (primary for notes generation)
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Local alias supported by code (if you already use this key name)
# MISTRELL_MODEL_API_KEY=your_mistral_api_key_here

# OpenRouter fallback (free model only)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=Audio2Notes AI
OPENROUTER_FREE_ONLY=true

# Optional local Ollama fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2:latest

# Whisper model size: tiny | base | small | medium | large
WHISPER_MODEL_SIZE=base

# Audio temp directory
AUDIO_TEMP_DIR=temp_audio
